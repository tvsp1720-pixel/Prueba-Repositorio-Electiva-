   "source": [
    "# Grafica Proyecto\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Datos\n",
    "x = [1, 2, 3, 4, 5]\n",
    "y = [2, 4, 6, 8, 10]\n",
    "\n",
    "# Crear la gráfica\n",
    "plt.plot(x, y, color='blue', marker='o', linestyle='--')\n",
    "\n",
    "# Etiquetas\n",
    "plt.title(\"Mi primera gráfica\")\n",
    "plt.xlabel(\"Eje X\")\n",
    "plt.ylabel(\"Eje Y\")\n",
    "\n",
    "# Mostrar\n",
    "plt.show()"
   ]
  }
